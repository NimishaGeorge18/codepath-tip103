class Node:
    def __init__(self, value, next=None):
        self.value = value
        self.next = next

# For testing
def print_linked_list(head):
    current = head
    while current:
        print(current.value, end=" -> " if current.next else "\n")
        current = current.next

def delete_dupes(head):
    tempHead = Node(0)
    tempHead.next = head
    prev = tempHead
    cur = head
    while cur:
        if cur.next and cur.value == cur.next.value:
            duplicate = cur.value
            while cur and cur.value == duplicate:
                cur = cur.next
            prev.next = cur
        else:
            prev = cur
            cur = cur.next
    return tempHead.next

head = Node(1, Node(2, Node(3, Node(3, Node(4, Node(5))))))

# Linked List: 1 -> 2 -> 3 -> 3 -> 4 -> 5
print_linked_list(delete_dupes(head))
        