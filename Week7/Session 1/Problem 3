def can_split_coffee(coffee, n):
    total = sum(coffee)
    if total % n != 0:
        return False

    target = total // n
    used = set()

    def dfs(groups_left, current_sum, start):
        if groups_left == 0:
            return True

        if current_sum == target:
            return dfs(groups_left - 1, 0, 0)

        for i in range(start, len(coffee)):
            if i not in used and current_sum + coffee[i] <= target:
                used.add(i)

                if dfs(groups_left, current_sum + coffee[i], i + 1):
                    return True

                used.remove(i)

        return False

    return dfs(n, 0, 0)
