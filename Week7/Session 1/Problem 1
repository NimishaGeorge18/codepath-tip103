'''
without recursion we can do this using stack

def count_layers(sandwich):
    count = 0
    stack = [sandwich]

    while stack:
        current = stack.pop()

        for item in current:
            if type(item) == list:
                stack.append(item)
            else:
                count += 1

    return count
